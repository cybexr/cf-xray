# Required: Cloudflare Tunnel Token
# Get this from your Cloudflare Zero Trust dashboard
TUNNEL_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Required: VLESS UUID for client authentication
# Generate with: uuidgen (Linux/macOS) or https://www.uuidgenerator.net/
VLESS_UUID=12345678-1234-1234-1234-123456789abc

# Optional: XHTTP path for VLESS transport (default: /your-secret-path)
# This path is used in the XHTTP transport configuration
# Make sure your client configuration uses the same path
VLESS_XHTTP_PATH=/your-secret-path

# Required: Your domain configured in Cloudflare Tunnel
DOMAIN=your.domain.com

# Required: TLS certificate and key files
# Default paths: /etc/xray/certs/fullchain.pem and /etc/xray/certs/privkey.pem
# You can mount your certificates or set custom paths
TLS_CERT_FILE=/etc/xray/certs/fullchain.pem
TLS_KEY_FILE=/etc/xray/certs/privkey.pem

# Optional: Xray inbound port (default: 10000)
PORT=10000

# Optional: Xray log level (default: warning)
# Options: debug, info, warning, error, none
LOG_LEVEL=warning

# Optional: Enable health check server on port 8080 (default: true)
ENABLE_HEALTH_CHECK=true
